# tugboat.env — non-secret, per-project Tugboat variables (committed, seeded once).
# Dashboard env vars of the same name win; SECRETS go in the dashboard only.

# --- Project basics --------------------------------------------------------
: "${CMS:=drupal}"
: "${PROJECT_DOCROOT:=docroot}"            # Acquia's Drupal docroot

# --- Front-end build -------------------------------------------------------
: "${BUILD_THEME:=true}"
: "${NODE_PACKAGE_MANAGER:=npm}"
: "${THEME_PATH:=docroot/themes/custom/mytheme}"
: "${THEME_BUILD_COMMAND:=build:prod}"

# --- Source environment (Acquia, via drush alias over SSH) -----------------
# Add the Acquia SSH key in the Tugboat dashboard (Repository Settings -> SSH).
: "${DRUSH_ALIAS:=@mysite.prod}"          # source for DB + files
: "${PROD_URL:=https://www.example.com}"  # stage_file_proxy origin / search-replace

# --- File handling (both conditions are independent) -----------------------
: "${FILES_PROXY:=true}"                  # stage_file_proxy missing files from PROD_URL
: "${FILES_RSYNC:=false}"                 # drush rsync the files directory down from DRUSH_ALIAS

# --- Preview conveniences --------------------------------------------------
: "${BUILD_CYPRESS_USERS:=true}"          # create test users for Cypress
